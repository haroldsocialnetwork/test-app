    "dotenv": "^17.4.2",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
